<Window x:Class="Nulmesis.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Nulmesis.App"
        mc:Ignorable="d"
        Title="Nulmesis" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏和根目录显示 -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
            <TextBlock Text="当前根目录：" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Text="{Binding RootDirectory, Mode=OneWay}" 
                     IsReadOnly="True" 
                     Background="{x:Static SystemColors.ControlBrush}"
                     Padding="5"/>
        </StackPanel>

        <!-- 控制面板 -->
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="扫描模式：" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox Grid.Column="1" 
                      ItemsSource="{Binding AvailableModes}" 
                      SelectedItem="{Binding SelectedMode}"
                      Width="120"
                      Margin="0,0,10,0"
                      VerticalAlignment="Center"/>

            <Button Grid.Column="2" 
                    Content="重新扫描" 
                    Command="{Binding ScanCommand}"
                    Width="100"
                    Margin="0,0,10,0"
                    Padding="10,5"/>

            <Button Grid.Column="3" 
                    Content="删除选中" 
                    Command="{Binding DeleteCommand}"
                    Width="100"
                    Padding="10,5"/>
        </Grid>

        <!-- 状态显示 -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" 
                       Text="{Binding StatusMessage}" 
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Text="命中数量：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding MatchCount}" 
                           VerticalAlignment="Center"
                           FontWeight="Bold"
                           Margin="0,0,15,0"/>
                <TextBlock Text="错误数量：" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBlock Text="{Binding ErrorCount}" 
                           VerticalAlignment="Center"
                           FontWeight="Bold"/>
            </StackPanel>
        </Grid>

        <!-- 预览表格 -->
        <DataGrid Grid.Row="3" 
                  ItemsSource="{Binding Matches}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Extended"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="{x:Static SystemColors.ControlLightBrush}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="相对路径" 
                                    Binding="{Binding RelativePath}" 
                                    Width="*"/>
                <DataGridTextColumn Header="大小" 
                                    Binding="{Binding SizeBytes, StringFormat={}{0:N0} 字节}"
                                    Width="100"/>
                <DataGridTextColumn Header="最后修改时间" 
                                    Binding="{Binding LastWriteTimeUtc, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}"
                                    Width="180"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 错误摘要区域 -->
        <Expander Grid.Row="4" Header="删除错误" IsExpanded="False" Margin="0,10,0,0">
            <ListBox ItemsSource="{Binding DeleteErrors}" 
                     MaxHeight="150"
                     Margin="5">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{Binding Path}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Expander>
    </Grid>
</Window>